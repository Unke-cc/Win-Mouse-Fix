{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://winmousefix.local/config.schema.json",
  "title": "Win Mouse Fix configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "configVersion",
    "enabled",
    "pauseInFullscreen",
    "doubleClickSpeed",
    "desktopSwipeDirection",
    "remaps",
    "scroll",
    "excludedApps",
    "startup"
  ],
  "properties": {
    "configVersion": { "const": 2 },
    "enabled": { "type": "boolean" },
    "pauseInFullscreen": { "type": "boolean" },
    "receiveBetaUpdates": { "type": "boolean", "default": false },
    "doubleClickSpeed": { "enum": ["fast", "medium", "slow"] },
    "desktopSwipeDirection": { "enum": ["followMouse", "oppositeMouse"] },
    "remaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/remap" }
    },
    "scroll": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reverse", "speed", "smooth"],
      "properties": {
        "reverse": { "type": "boolean" },
        "speed": { "type": "number", "minimum": 0.25, "maximum": 4.0 },
        "smooth": { "type": "boolean" },
        "horizontalModifier": { "$ref": "#/$defs/modifier" },
        "fastModifier": { "$ref": "#/$defs/modifier" },
        "precisionModifier": { "$ref": "#/$defs/modifier" },
        "zoomModifier": { "$ref": "#/$defs/modifier" }
      }
    },
    "excludedApps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path", "mode"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "mode": { "const": "disableAll" }
        }
      }
    },
    "startup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runAtLogin"],
      "properties": {
        "runAtLogin": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "remap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["button", "trigger", "action"],
      "properties": {
        "button": { "enum": ["MButton", "XButton1", "XButton2"] },
        "trigger": {
          "enum": [
            "click",
            "doubleClick",
            "hold",
            "holdScroll",
            "holdDrag",
            "dragUp",
            "dragDown",
            "dragLeft",
            "dragRight",
            "wheelUp",
            "wheelDown"
          ]
        },
        "action": { "$ref": "#/$defs/action" }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "shortcut"],
      "properties": {
        "type": {
          "enum": [
            "None",
            "Original",
            "Back",
            "Forward",
            "MiddleClick",
            "PrimaryClick",
            "SecondaryClick",
            "TaskView",
            "ShowDesktop",
            "StartMenu",
            "DesktopLeft",
            "DesktopRight",
            "AltTab",
            "CloseWindow",
            "CloseTab",
            "NextTab",
            "PreviousTab",
            "VolumeUp",
            "VolumeDown",
            "VolumeMute",
            "MediaPlayPause",
            "FastScroll",
            "Zoom",
            "VolumeControl",
            "TabNavigation",
            "BrowserNavigation",
            "DesktopSwitch",
            "DesktopStartMenu",
            "ScrollMove",
            "DesktopNavigation",
            "BrowserTabNavigation",
            "CustomShortcut"
          ]
        },
        "shortcut": { "type": "string" }
      }
    },
    "modifier": {
      "enum": ["none", "ctrl", "alt", "shift", "win"]
    }
  }
}
