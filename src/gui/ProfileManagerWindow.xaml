<Window x:Class="WinMouseFix.Gui.ProfileManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配置管理" Width="620" SizeToContent="Height" ResizeMode="NoResize"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner" Loaded="Window_Loaded">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="配置管理" Style="{StaticResource PageTitle}" />
            <TextBlock Text="切换、导入、导出和恢复不同的鼠标设置。"
                       Foreground="{StaticResource MutedTextBrush}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="配置档案" Style="{StaticResource SectionTitle}" />
                <TextBlock Text="切换前会保存当前设置；新建档案会复制当前设置。"
                           Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,14" />
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <ComboBox x:Name="ProfilesComboBox" MinWidth="320" />
                    <Button Grid.Column="1" Content="切换" Style="{StaticResource PrimaryButton}"
                            Margin="10,0,0,0" Click="SwitchProfile_Click" />
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                    <Button Content="新建副本" Click="CreateProfile_Click" Margin="0,0,10,0" />
                    <Button Content="重命名" Click="RenameProfile_Click" Margin="0,0,10,0" />
                    <Button Content="删除" Click="DeleteProfile_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="导入、导出与备份" Style="{StaticResource SectionTitle}" />
                <WrapPanel Margin="0,8,0,4">
                    <Button Content="导入配置…" Click="ImportConfig_Click" Margin="0,0,10,10" />
                    <Button Content="导出当前配置…" Click="ExportConfig_Click" Margin="0,0,10,10" />
                    <Button Content="立即备份" Click="CreateBackup_Click" Margin="0,0,10,10" />
                </WrapPanel>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <ComboBox x:Name="BackupsComboBox" MinWidth="320" ToolTip="选择要恢复的备份" />
                    <Button Grid.Column="1" Content="恢复所选备份" Margin="10,0,0,0"
                            Click="RestoreBackup_Click" />
                </Grid>
                <TextBlock x:Name="StorageLocationText" Margin="0,14,0,0" FontSize="11"
                           Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <Button Grid.Row="3" Content="完成" HorizontalAlignment="Right" MinWidth="88"
                Style="{StaticResource PrimaryButton}" Click="Close_Click" />
    </Grid>
</Window>
