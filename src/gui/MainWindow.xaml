<Window x:Class="WinMouseFix.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WinMouseFix.Gui.Controls"
        xmlns:componentModel="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        Title="Win Mouse Fix"
        Width="720" Height="640" MinWidth="660" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        PreviewMouseMove="Window_MouseActivity"
        PreviewMouseDown="Window_MouseActivity"
        PreviewMouseWheel="Window_MouseActivity"
        PreviewKeyDown="Window_KeyActivity"
        Closing="Window_Closing">
    <Window.Resources>
        <controls:TriggerActionOptionsConverter x:Key="TriggerActionOptionsConverter" />
        <controls:ModifierShortcutConverter x:Key="ModifierShortcutConverter" />
        <Style x:Key="TopNavigationItem" TargetType="RadioButton">
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="NavigationBorder" Background="Transparent" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavigationBorder" Property="Background" Value="#F7F8FA" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="NavigationBorder" Property="Background" Value="White" />
                                <Setter TargetName="NavigationBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12" />
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TriggerLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Text" Value="{Binding Trigger}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Trigger}" Value="click"><Setter Property="Text" Value="点击" /></DataTrigger>
                <DataTrigger Binding="{Binding Trigger}" Value="doubleClick"><Setter Property="Text" Value="双击" /></DataTrigger>
                <DataTrigger Binding="{Binding Trigger}" Value="hold"><Setter Property="Text" Value="长按" /></DataTrigger>
                <DataTrigger Binding="{Binding Trigger}" Value="holdScroll"><Setter Property="Text" Value="按住并滚动" /></DataTrigger>
                <DataTrigger Binding="{Binding Trigger}" Value="holdDrag"><Setter Property="Text" Value="按住并拖动" /></DataTrigger>
                <DataTrigger Binding="{Binding Trigger}" Value="dragUp"><Setter Property="Text" Value="向上拖动（旧设置）" /></DataTrigger>
                <DataTrigger Binding="{Binding Trigger}" Value="dragDown"><Setter Property="Text" Value="向下拖动（旧设置）" /></DataTrigger>
                <DataTrigger Binding="{Binding Trigger}" Value="dragLeft"><Setter Property="Text" Value="向左拖动（旧设置）" /></DataTrigger>
                <DataTrigger Binding="{Binding Trigger}" Value="dragRight"><Setter Property="Text" Value="向右拖动（旧设置）" /></DataTrigger>
                <DataTrigger Binding="{Binding Trigger}" Value="wheelUp"><Setter Property="Text" Value="向上滚动（旧设置）" /></DataTrigger>
                <DataTrigger Binding="{Binding Trigger}" Value="wheelDown"><Setter Property="Text" Value="向下滚动（旧设置）" /></DataTrigger>
            </Style.Triggers>
        </Style>

        <CollectionViewSource x:Key="GroupedRemaps" Source="{Binding Remaps}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Button" />
            </CollectionViewSource.GroupDescriptions>
            <CollectionViewSource.SortDescriptions>
                <componentModel:SortDescription PropertyName="Button" Direction="Ascending" />
                <componentModel:SortDescription PropertyName="TriggerOrder" Direction="Ascending" />
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
    </Window.Resources>

    <Grid x:Name="RootLayout">
        <Grid.RowDefinitions>
            <RowDefinition Height="68" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="145" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="145" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#EEF0F3" CornerRadius="10" Padding="3">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="GeneralNavigation" Content="通用" GroupName="Navigation"
                                     Style="{StaticResource TopNavigationItem}" Checked="Navigation_Checked" />
                        <RadioButton x:Name="ButtonsNavigation" Content="按钮" GroupName="Navigation"
                                     Style="{StaticResource TopNavigationItem}" Checked="Navigation_Checked" />
                        <RadioButton x:Name="ScrollNavigation" Content="滚动" GroupName="Navigation"
                                     Style="{StaticResource TopNavigationItem}" Checked="Navigation_Checked" />
                        <RadioButton x:Name="AboutNavigation" Content="关于" GroupName="Navigation"
                                     Style="{StaticResource TopNavigationItem}" Checked="Navigation_Checked" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse x:Name="AppStatusDot" Width="7" Height="7" Fill="#98A2B3" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ContentHost" Grid.Row="1">
            <ScrollViewer x:Name="GeneralPage" VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Disabled"
                          HorizontalContentAlignment="Center">
                <StackPanel Width="620" Margin="0,24,0,28">
                    <TextBlock Text="控制运行方式，以及在哪些应用中保留鼠标原始行为。" Style="{StaticResource PageDescription}" />

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="启动 Win Mouse Fix" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="开启后应用当前按钮与滚动设置。" Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                            <CheckBox x:Name="AppEnabledToggle" Grid.Column="1"
                                      Style="{StaticResource ToggleSwitch}"
                                      AutomationProperties.Name="启动 Win Mouse Fix"
                                      IsChecked="{Binding Enabled, Mode=TwoWay}"
                                      Click="AppEnabledToggle_Click" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="登录 Windows 后运行" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="登录后自动启动并应用已保存的设置。" Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                      AutomationProperties.Name="登录 Windows 后运行"
                                      IsChecked="{Binding Startup.RunAtLogin, Mode=TwoWay}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="全屏时自动暂停" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="适合游戏和演示；普通最大化窗口不受影响。" Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                      AutomationProperties.Name="全屏时自动暂停"
                                      IsChecked="{Binding PauseInFullscreen, Mode=TwoWay}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="应用排除" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="进入列表中的应用后，按钮和滚动保持系统原始行为。"
                                       Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,14" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox x:Name="ApplicationPathTextBox" MinWidth="380" ToolTip="应用 .exe 路径" />
                                <Button Grid.Column="1" Content="浏览" Margin="8,0" Click="BrowseApplication_Click" />
                                <Button Grid.Column="2" Content="添加" Style="{StaticResource PrimaryButton}" Click="AddApplication_Click" />
                            </Grid>
                            <TextBlock x:Name="EmptyApplicationsText" Text="还没有添加应用。"
                                       Foreground="{StaticResource MutedTextBrush}" Margin="0,16,0,0" />
                            <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding ExcludedApps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <Border Background="#F7F9FC" CornerRadius="9" Padding="12">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Path}" Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="11" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                                <Button Grid.Column="1" Content="移除" Margin="8,0,0,0"
                                                        CommandParameter="{Binding}" Click="RemoveApplication_Click" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                        <Button Content="配置管理…" HorizontalAlignment="Left" Click="OpenProfileManager_Click" />
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="ButtonsPage" Visibility="Collapsed" Width="620" Margin="0,20,0,18"
                  HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="CaptureArea" Height="190" Margin="0,0,0,12" CornerRadius="8"
                        BorderBrush="#DEE1E6" BorderThickness="1" Background="#ECEEF1"
                        MouseEnter="CaptureArea_MouseEnter" MouseLeave="CaptureArea_MouseLeave"
                        PreviewMouseDown="CaptureArea_PreviewMouseDown"
                        PreviewMouseUp="CaptureArea_PreviewMouseUp"
                        PreviewMouseMove="CaptureArea_PreviewMouseMove"
                        PreviewMouseWheel="CaptureArea_PreviewMouseWheel"
                        LostMouseCapture="CaptureArea_LostMouseCapture">
                    <Border.RenderTransform>
                        <TranslateTransform />
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="14" ShadowDepth="3" Opacity="0" />
                    </Border.Effect>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                     To="-2" Duration="0:0:0.14" />
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                     To="0.14" Duration="0:0:0.14" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                     To="0" Duration="0:0:0.14" />
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                     To="0" Duration="0:0:0.14" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="＋" FontSize="44" FontWeight="Light" Foreground="#7C8491"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="CaptureStateText" Text="鼠标移入这里即可录入"
                                   Height="20" Margin="0,6,0,0" FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" Margin="2,0,2,14">
                    <TextBlock Text="将鼠标移入“+”区域，然后按下鼠标按钮来指定操作。" />
                    <TextBlock Text="也可以双击、长按、点击并滚动或拖动。"
                               Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                </StackPanel>

                <Border x:Name="MappingsPanel" Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Margin="0,0,0,12"
                        MinHeight="180">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="EmptyRemapsText"
                                   Text="还没有映射。将鼠标移入上方区域并完成一个操作。"
                                   Foreground="{StaticResource MutedTextBrush}" Margin="14,12" />
                        <ListBox Grid.Row="1" x:Name="RemapsList" ItemsSource="{Binding Source={StaticResource GroupedRemaps}}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <Border Background="#F4F5F7" Padding="12,7">
                                                    <TextBlock FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="鼠标按钮" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Name}" Value="MButton"><Setter Property="Text" Value="中键" /></DataTrigger>
                                                                    <DataTrigger Binding="{Binding Name}" Value="XButton1"><Setter Property="Text" Value="按键4（后退键）" /></DataTrigger>
                                                                    <DataTrigger Binding="{Binding Name}" Value="XButton2"><Setter Property="Text" Value="按键5（前进键）" /></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ListBox.GroupStyle>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="10,5" />
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="38" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            <Button Content="−" Width="30" Height="30" MinWidth="30" MinHeight="30"
                                                    Padding="0" ToolTip="删除映射"
                                                    CommandParameter="{Binding}" Click="RemoveRemap_Click" />
                                            <TextBlock Grid.Column="1" Style="{StaticResource TriggerLabel}" />
                                            <ComboBox Grid.Column="2" Margin="0,0,8,0"
                                                      ToolTip="选择这个操作要执行的动作。"
                                                      ItemsSource="{Binding Trigger, Converter={StaticResource TriggerActionOptionsConverter}}"
                                                      SelectedValuePath="Type"
                                                      PreviewMouseWheel="RemapComboBox_PreviewMouseWheel"
                                                      SelectedValue="{Binding Action.Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBox Grid.Column="3" ToolTip="例如 Ctrl+Shift+T"
                                                     Visibility="{Binding Action.Type, Converter={StaticResource ActionTypeToVisibilityConverter}}"
                                                     Text="{Binding Action.Shortcut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                    <Grid>
                        <Button Content="选项…" HorizontalAlignment="Left" Click="OpenButtonOptions_Click" />
                        <Button Content="恢复默认值..." HorizontalAlignment="Right" Click="RestoreDefaults_Click" />
                    </Grid>
                </Border>
            </Grid>

            <ScrollViewer x:Name="ScrollPage" Visibility="Collapsed" VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Disabled"
                          HorizontalContentAlignment="Center">
                <StackPanel Width="620" Margin="0,24,0,28">
                    <TextBlock Text="调整普通滚轮，以及修饰键配合滚轮执行的动作。" Style="{StaticResource PageDescription}" />

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="反向滚动" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="让滚轮方向与 Windows 默认方向相反。" Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                      AutomationProperties.Name="反向滚动"
                                      IsChecked="{Binding Scroll.Reverse, Mode=TwoWay}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="滚轮速度" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="较低适合精细阅读，较高适合快速浏览。" Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" x:Name="ScrollSpeedText" Text="1.0×" FontSize="18"
                                           FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" />
                            </Grid>
                            <Slider Minimum="0.25" Maximum="4" TickFrequency="0.25" IsSnapToTickEnabled="True"
                                    Style="{StaticResource ScrollSpeedSlider}"
                                    Value="{Binding Scroll.Speed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ValueChanged="ScrollSpeed_ValueChanged" />
                            <Grid Margin="0,6,0,0">
                                <TextBlock Text="0.25×" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                <TextBlock Text="4×" Foreground="{StaticResource MutedTextBrush}" FontSize="11" HorizontalAlignment="Right" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="基础平滑" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="减少滚轮每一格之间的跳跃感。" Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                      AutomationProperties.Name="基础平滑"
                                      IsChecked="{Binding Scroll.Smooth, Mode=TwoWay}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="修饰键" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="按住 Ctrl、Alt、Shift、Win，或中键、按键4、按键5并滚动滚轮，即可执行对应动作。"
                                       Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,14" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Margin="0,0,10,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="150" /></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="水平滚动" FontWeight="SemiBold" />
                                        <TextBlock Text="上滚向左，下滚向右。" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Tag="HorizontalModifier" IsReadOnly="True"
                                             Text="{Binding Scroll.HorizontalModifier, Converter={StaticResource ModifierShortcutConverter}}"
                                             PreviewKeyDown="ModifierShortcutBox_PreviewKeyDown"
                                             PreviewMouseDown="ModifierShortcutBox_PreviewMouseDown"
                                             ToolTip="按下键盘修饰键或鼠标按钮；按 Delete 清除" />
                                </Grid>

                                <Grid Grid.Column="1" Margin="10,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="150" /></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="快速滚动" FontWeight="SemiBold" />
                                        <TextBlock Text="当前速度的 4 倍。" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Tag="FastModifier" IsReadOnly="True"
                                             Text="{Binding Scroll.FastModifier, Converter={StaticResource ModifierShortcutConverter}}"
                                             PreviewKeyDown="ModifierShortcutBox_PreviewKeyDown"
                                             PreviewMouseDown="ModifierShortcutBox_PreviewMouseDown"
                                             ToolTip="按下键盘修饰键或鼠标按钮；按 Delete 清除" />
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,0,10,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="150" /></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="精确滚动" FontWeight="SemiBold" />
                                        <TextBlock Text="当前速度的四分之一。" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Tag="PrecisionModifier" IsReadOnly="True"
                                             Text="{Binding Scroll.PrecisionModifier, Converter={StaticResource ModifierShortcutConverter}}"
                                             PreviewKeyDown="ModifierShortcutBox_PreviewKeyDown"
                                             PreviewMouseDown="ModifierShortcutBox_PreviewMouseDown"
                                             ToolTip="按下键盘修饰键或鼠标按钮；按 Delete 清除" />
                                </Grid>

                                <Grid Grid.Row="1" Grid.Column="1" Margin="10,0,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="150" /></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="放大或缩小" FontWeight="SemiBold" />
                                        <TextBlock Text="在支持的应用中缩放。" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Tag="ZoomModifier" IsReadOnly="True"
                                             Text="{Binding Scroll.ZoomModifier, Converter={StaticResource ModifierShortcutConverter}}"
                                             PreviewKeyDown="ModifierShortcutBox_PreviewKeyDown"
                                             PreviewMouseDown="ModifierShortcutBox_PreviewMouseDown"
                                             ToolTip="按下键盘修饰键或鼠标按钮；按 Delete 清除" />
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="AboutPage" Visibility="Collapsed" VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Disabled"
                          HorizontalContentAlignment="Center">
                <StackPanel Width="620" Margin="0,24,0,28">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Win Mouse Fix" Style="{StaticResource SectionTitle}" />
                                    <TextBlock x:Name="AboutVersionText" Text="版本" Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                                <Image Grid.Column="1" Width="48" Height="48" Source="/assets/WinMouseFix.png"
                                       Stretch="Uniform" SnapsToDevicePixels="True"
                                       AutomationProperties.Name="Win Mouse Fix 图标" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="作者" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10" />
                                <TextBlock Grid.Column="1" Text="胡文凯" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="1" Text="许可状态" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="个人非商业使用免费；其他用途需另行许可" Margin="0,0,0,10" />
                                <TextBlock Grid.Row="2" Text="项目主页" Foreground="{StaticResource MutedTextBrush}" />
                                <StackPanel Grid.Row="2" Grid.Column="1">
                                    <TextBlock x:Name="ProjectHomepageText" Text="正在检测 GitHub / Gitee" />
                                    <TextBlock x:Name="AboutSourceStatusText" Margin="0,3,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="将根据网络自动选择 GitHub 或 Gitee" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                <Button x:Name="CheckForUpdatesButton" Content="检查更新" Style="{StaticResource PrimaryButton}"
                                        Click="CheckForUpdates_Click" Margin="0,0,10,0" />
                                <Button x:Name="OpenProjectHomepageButton" Content="打开项目主页" Click="OpenProjectHomepage_Click" Margin="0,0,10,0" />
                                <Button x:Name="OpenLicenseButton" Content="查看许可" Click="OpenLicense_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="获取 Beta 版更新" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="开启后同时检查测试版本；默认只检查正式版本。"
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                      AutomationProperties.Name="获取 Beta 版更新"
                                      IsChecked="{Binding ReceiveBetaUpdates, Mode=TwoWay}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="配置文件" Style="{StaticResource SectionTitle}" />
                            <TextBlock x:Name="ConfigPathText" Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border x:Name="StatusBar" Grid.Row="2" Background="#172033" Padding="16,10" Visibility="Collapsed">
            <Grid>
                <TextBlock x:Name="StatusMessageText" Foreground="White" />
                <Button Content="关闭" MinWidth="52" MinHeight="28" Padding="10,4"
                        HorizontalAlignment="Right" Click="CloseStatus_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
