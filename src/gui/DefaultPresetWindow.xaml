<Window x:Class="WinMouseFix.Gui.DefaultPresetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="恢复默认值" Width="520" SizeToContent="Height"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="恢复默认值" Style="{StaticResource PageTitle}" />
            <TextBlock Text="选择适合鼠标类型的默认按键设置。当前设置会被替换。"
                       Foreground="{StaticResource MutedTextBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="1">
            <Button x:Name="ThreeButtonPresetButton" Click="ThreeButtonPreset_Click"
                    HorizontalContentAlignment="Stretch" Margin="0,0,0,12" Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="三键鼠标" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="中键：点击中键、长按显示桌面、连按开始菜单、拖动切换虚拟桌面"
                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,4,12,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock x:Name="ThreeButtonRecommendedText" Grid.Column="1" Text="推荐"
                               Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"
                               VerticalAlignment="Center" Visibility="Collapsed" />
                </Grid>
            </Button>

            <Button x:Name="FiveOrMorePresetButton" Click="FiveOrMorePreset_Click"
                    HorizontalContentAlignment="Stretch" Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="五键或多键鼠标" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="按键 4：后退、桌面与开始菜单、虚拟桌面与任务视图&#10;按键 5：前进、缩放、滚动与移动"
                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,4,12,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock x:Name="FiveOrMoreRecommendedText" Grid.Column="1" Text="推荐"
                               Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"
                               VerticalAlignment="Center" Visibility="Collapsed" />
                </Grid>
            </Button>
        </StackPanel>

        <Button Grid.Row="2" Content="取消" HorizontalAlignment="Right" Margin="0,18,0,0"
                MinWidth="88" IsCancel="True" Click="Cancel_Click" />
    </Grid>
</Window>
